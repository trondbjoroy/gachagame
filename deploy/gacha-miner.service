[Unit]
Description=Hathor Gacha - local tx-mining service (:8035)
After=network-online.target
Wants=network-online.target

[Service]
User=gacha
WorkingDirectory=/opt/gacha
ExecStart=/opt/gacha/venv/bin/python /opt/gacha/miner/miner.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
