[Unit]
Description=Hathor Gacha - wallet-headless (:8000, localhost only)
After=network-online.target gacha-miner.service
Wants=network-online.target

[Service]
User=gacha
WorkingDirectory=/opt/gacha/wallet-headless
ExecStart=/usr/bin/node dist/index.js
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
