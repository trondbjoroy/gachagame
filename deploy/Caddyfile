# DNS A records -> this VPS: emberfall.fun, www.emberfall.fun, app.emberfall.fun, docs.emberfall.fun
# Caddy provisions Let's Encrypt TLS automatically.

# landing page (static)
emberfall.fun {
	root * /opt/gacha/landing
	file_server
	encode gzip
}

www.emberfall.fun {
	redir https://emberfall.fun{uri} permanent
}

# the game itself
app.emberfall.fun {
	encode gzip
	# the in-browser session wallet syncs with the fullnode through us
	# (some phones refuse direct connections to the node's host); this
	# also carries the wallet's websocket
	handle_path /hnode/* {
		reverse_proxy https://node-partners.testnet.hathor.network {
			header_up Host {upstream_hostport}
		}
	}
	handle {
		reverse_proxy 127.0.0.1:8090
	}
}

# the game guide (static)
docs.emberfall.fun {
	root * /opt/gacha/guide
	file_server
	encode gzip
}
